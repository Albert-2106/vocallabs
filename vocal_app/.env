# ─────────────────────────────────────────────────────────────────────────────
# Outreach Pipeline — Environment Configuration
# Copy this to .env and fill in the values you have.
# Every field is optional — the pipeline has fallbacks for everything.
# ─────────────────────────────────────────────────────────────────────────────

# ── Stage 1: Company Discovery ────────────────────────────────────────────────
# SerpAPI (100 free searches/month) — https://serpapi.com
# If not set, Clearbit autocomplete (no key needed) is tried first,
# then the built-in curated dataset.
SERPAPI_KEY= 


# ── Stage 2 + 3: Lead & Email Resolution ─────────────────────────────────────
# Hunter.io (25 free req/month) — https://hunter.io
# Provides domain-search (leads) + email-finder + email-verifier.
# Without this key, the pipeline uses its static dataset + pattern guessing.
HUNTER_API_KEY= 
